# ============================================
# Server Configuration
# ============================================
PORT=5000
HOST=0.0.0.0
DEBUG=True

# Optional public backend URL used by dashboard URL/curl examples
# Set this to your deployed backend domain in production.
PUBLIC_BASE_URL=http://localhost:5000

# ============================================
# Filesystem Storage Configuration
# ============================================
# Linux storage server mount path (example)
STORAGE_PATH_LINUX=/mnt/hdf5-storage

# Windows storage server path (example: local drive or UNC share)
STORAGE_PATH_WINDOWS=C:\Coding\HDF Viewer\backend_2\files

# Optional explicit override root (takes precedence when set)
STORAGE_ROOT=C:\Coding\HDF Viewer\backend_2\files
